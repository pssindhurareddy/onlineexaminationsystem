# --- RAILWAY (BACKEND) ENVIRONMENT VARIABLES ---
NODE_ENV=production
PORT=5000

# Database (Railway will provide a DATABASE_URL)
DATABASE_URL=postgres://user:pass@host:port/dbname

# Redis (Railway will provide a REDIS_URL)
REDIS_URL=redis://user:pass@host:port

# Security
JWT_ACCESS_SECRET=your_32_char_plus_access_secret
JWT_REFRESH_SECRET=your_32_char_plus_refresh_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Frontend URL (For CORS - e.g. https://exampro.vercel.app)
FRONTEND_URL=https://your-app.vercel.app

# Email (SMTP)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_user
SMTP_PASS=your_pass
SMTP_FROM=noreply@yourdomain.edu

# --- VERCEL (FRONTEND) ENVIRONMENT VARIABLES ---
# In Vercel dashboard, set this to your Railway URL (e.g. https://exampro-production.up.railway.app)
VITE_API_URL=https://your-backend.up.railway.app/api/v1
