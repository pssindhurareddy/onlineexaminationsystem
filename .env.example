# App
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=examdb
DB_USER=examuser
DB_PASSWORD=strongpassword123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispassword123

# JWT (generate RSA keys: openssl genrsa -out private.pem 2048)
JWT_ACCESS_SECRET=your_access_secret_min_32_chars_long_enough
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_long_enough
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=ExamPro <noreply@exampro.com>

# Frontend env
VITE_API_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000
